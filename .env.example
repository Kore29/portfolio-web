# Next.js Application Environment Variables Example
# Copy this file to .env.local for local development, and .env.production for production.

# Public Environment Variables (prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id

# Server-only Environment Variables (secrets)
# DATABASE_URL=postgresql://user:password@localhost:5432/db
# API_SECRET_KEY=your-secret-key
